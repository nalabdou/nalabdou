---
import { FrNumber } from "../helpers/Number";

const {
  title,
  img,
  desc,
  url,
  badge,
  tags,
  target = "_blank",
  installs,
  invert = false,
} = Astro.props;
---

<div
  class={`rounded-lg ${
    invert ? "bg-base-200" : "bg-base-100"
  } hover:shadow-xl transition ease-in-out hover:scale-[102%]`}
>
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">
      {
        img && (
          <img
            loading="lazy"
            src={img}
            alt={title}
            class="max-w-full md:max-w-[9rem] rounded-lg"
          />
        )
      }
      <div class="grow w-full">
        <h1 class="text-xl font-bold">
          {title}
          {badge && <div class={`badge badge-primary mx-2`}>{badge}</div>}
        </h1>
        <p class="py-1 text-1xl">{desc}</p>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag: string) => (
                <div class="badge badge-outline">{tag}</div>
              ))
          }
          {
            installs && (
              <div class="badge badge-outline">{`${FrNumber(
                installs
              )} installations`}</div>
            )
          }
        </div>
      </div>
    </div>
  </a>
</div>
