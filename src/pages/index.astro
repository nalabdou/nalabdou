---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const projects = (await getCollection("projets")).sort(
  (b, a) => b.data.pos - a.data.pos
);

const last_posts = posts.slice(0, 3);
const last_projets = projects.slice(0, 3);
---

<BaseLayout>
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Sàlü 👋</div>
    <div class="text-3xl py-3 font-bold">Nadim - Développeur Web Symfony</div>
    <div class="py-2">
      <text class="text-lg">
        Je suis un développeur Symfony Je travaille chez <a
          class="link text-blue-600 font-bold"
          href="https://www.actimage.com/fr/"
          target="_blank">@Actimage</a
        > à Strasbourg. Mon travail consiste à contribuer au développement du site
        gouvernemental français, <a
          href="https://gouvernement.fr/"
          target="_blank"
          class="link text-blue-600 font-bold">Gouvernement.fr</a
        >.
      </text>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-10">Mes derniers projets 🗂️</div>
  </div>

  {
    last_projets.map((projet) => (
      <>
        <HorizontalCard
          title={projet.data.title}
          img={projet.data.icon}
          desc={projet.data.description}
          url={projet.data.link}
          tags={projet.data.tags}
          badge={projet.data.badge}
          invert={true}
        />
        <div class="divider my-0" />
      </>
    ))
  }

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">
      Derniers articles du blog 📰
    </div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + post.slug}
          target="_self"
          badge={post.data.badge}
          tags={post.data.tags}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
