---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";

import { SITE_TITLE, SITE_DESCRIPTION } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  useTitle = false,
  full = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" data-theme="pastel">
  <head>
    <BaseHead
      title={useTitle ? `${SITE_TITLE} | ${title}` : title}
      description={description}
      image={image}
    />
  </head>
  <body>
    <div class="bg-base-100 drawer drawer-mobile">
      <label for="s-drawer" class="sr-only"></label>
      <input id="s-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col bg-base-100">
        <Header title={SITE_TITLE} />
        <div class="md:flex md:justify-center">
          <main class={`p-6 pt-10 ${full ? "w-full" : "max-w-[900px]"}`}>
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar />}
    </div>
  </body>
</html>
